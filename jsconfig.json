{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "checkJs": true,
    "noEmit": true,
    "allowJs": true,
    "strictNullChecks": false,
    "noImplicitAny": false,
    "baseUrl": ".",
    "paths": {
      "src/*": ["src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "proxy", "scripts"]
}
